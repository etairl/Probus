{
  "name": "probus",
  "version": "0.1.1",
  "description": "Agentic security scanner for code repos — analyst + primary + secondary agent pipeline over OpenRouter / OpenAI / Anthropic models, with a live Ink terminal UI.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "probus contributors",
  "homepage": "https://github.com/ItayRosen/Probus",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItayRosen/Probus.git"
  },
  "bugs": {
    "url": "https://github.com/ItayRosen/Probus/issues"
  },
  "keywords": [
    "security",
    "pentest",
    "sast",
    "vulnerability-scanner",
    "llm",
    "agent",
    "openrouter",
    "claude",
    "cli",
    "ink"
  ],
  "bin": {
    "probus": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.118",
    "@maximhq/bifrost": "^1.6.2",
    "ink": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
