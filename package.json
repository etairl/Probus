{
  "name": "probus",
  "version": "0.1.0",
  "description": "Agentic security scanner for code repos — analyst + researcher + QA pipeline over OpenRouter models, with a live Ink terminal UI.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "probus contributors",
  "homepage": "https://github.com/ItayRosen/Probus",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItayRosen/Probus.git"
  },
  "bugs": {
    "url": "https://github.com/ItayRosen/Probus/issues"
  },
  "keywords": [
    "security",
    "pentest",
    "sast",
    "vulnerability-scanner",
    "llm",
    "agent",
    "openrouter",
    "claude",
    "cli",
    "ink"
  ],
  "bin": {
    "probus": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
